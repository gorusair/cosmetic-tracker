rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/products/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/productChanges/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/skinEvents/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/usageLogs/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/usagelogs/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /cosmetics/{docId} {
      allow read, write: if false;
    }

    match /usagelogs/{docId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    match /visits/{docId} {
      allow create: if request.resource.data.keys().hasOnly([
          "createdAt",
          "page",
          "source",
          "referrer",
          "userAgent",
          "language",
          "isAnonymous",
          "uid",
          "loggedDate"
        ])
        && request.resource.data.keys().hasAll([
          "createdAt",
          "page",
          "source",
          "referrer",
          "userAgent",
          "language",
          "isAnonymous",
          "uid",
          "loggedDate"
        ])
        && request.resource.data.createdAt == request.time
        && request.resource.data.page is string
        && request.resource.data.source is string
        && request.resource.data.referrer is string
        && request.resource.data.userAgent is string
        && request.resource.data.language is string
        && request.resource.data.isAnonymous is bool
        && (request.resource.data.uid == null || request.resource.data.uid is string)
        && request.resource.data.loggedDate is string;
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
