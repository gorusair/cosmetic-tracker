rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/products/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/productChanges/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/skinEvents/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/depletionNotifications/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/usageLogs/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/usagelogs/{docId} {
      allow read, write: if isOwner(userId);
    }

    match /cosmetics/{docId} {
      allow read, write: if false;
    }

    match /usagelogs/{docId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    match /skinLogs/{docId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    match /visits/{docId} {
      allow create: if request.resource.data.keys().hasOnly([
          "createdAt",
          "readableTime",
          "page",
          "search",
          "from",
          "source",
          "referrer",
          "uid",
          "isAnonymous",
          "language",
          "userAgent",
          "deviceType",
          "viewportWidth",
          "viewportHeight"
        ])
        && request.resource.data.keys().hasAll([
          "createdAt",
          "readableTime",
          "page",
          "search",
          "from",
          "source",
          "referrer",
          "uid",
          "isAnonymous",
          "language",
          "userAgent",
          "deviceType",
          "viewportWidth",
          "viewportHeight"
        ])
        && request.resource.data.createdAt == request.time
        && request.resource.data.readableTime is string
        && request.resource.data.page is string
        && request.resource.data.search is string
        && request.resource.data.from is string
        && request.resource.data.source is string
        && request.resource.data.referrer is string
        && request.resource.data.uid is string
        && request.resource.data.isAnonymous is bool
        && request.resource.data.language is string
        && request.resource.data.userAgent is string
        && request.resource.data.deviceType in ["mobile", "desktop"]
        && request.resource.data.viewportWidth is number
        && request.resource.data.viewportHeight is number;
      allow read, update, delete: if false;
    }

    match /events/{docId} {
      allow create: if request.resource.data.keys().hasOnly([
          "eventName",
          "createdAt",
          "readableTime",
          "page",
          "from",
          "source",
          "uid",
          "isAnonymous",
          "deviceType"
        ])
        && request.resource.data.keys().hasAll([
          "eventName",
          "createdAt",
          "readableTime",
          "page",
          "from",
          "source",
          "uid",
          "isAnonymous",
          "deviceType"
        ])
        && request.resource.data.eventName in [
          "visit",
          "start_clicked",
          "anonymous_login",
          "google_login",
          "product_added",
          "today_used",
          "calendar_opened",
          "email_alert_clicked"
        ]
        && request.resource.data.createdAt == request.time
        && request.resource.data.readableTime is string
        && request.resource.data.page is string
        && request.resource.data.from is string
        && request.resource.data.source is string
        && request.resource.data.uid is string
        && request.resource.data.isAnonymous is bool
        && request.resource.data.deviceType in ["mobile", "desktop"];
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
